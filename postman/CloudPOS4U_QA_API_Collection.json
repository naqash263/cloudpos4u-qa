  "item": [
    {
      "name": "Login Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Login success is true\", function () {",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "",
              "pm.test(\"Access token exists\", function () {",
              "    pm.expect(jsonData.accessToken).to.be.a(\"string\");",
              "});",
              "",
              "pm.test(\"User role is Admin\", function () {",
              "    pm.expect(jsonData.data.role).to.eql(\"Admin\");",
              "});",
              "",
              "pm.environment.set(\"accessToken\", jsonData.accessToken);",
              "pm.environment.set(\"branchId\", jsonData.data.branchId);",
              "pm.environment.set(\"branchCode\", jsonData.data.branch.code);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/user/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "user",
            "login"
          ]
        }
      },
      "response": []
    },
