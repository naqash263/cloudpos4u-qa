              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Invalid credentials message exists\", function () {",
              "    pm.expect(jsonData.message).to.eql(\"Invalid Credentials\");",
              "});",
              "",
              "pm.test(\"No access token should be returned\", function () {",
              "    pm.expect(jsonData.accessToken).to.be.undefined;",
              "});"
